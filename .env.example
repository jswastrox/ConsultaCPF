# Banco de dados (Neon Postgres)
# Formato: postgresql+psycopg://usuario:senha@host/dbname?sslmode=require
DATABASE_URL=postgresql+psycopg://user:password@ep-xxxx.neon.tech/consultacpf?sslmode=require

# Provedor de dados de CPF (adapter plugável). "mock" = dados fictícios de
# demonstração; troque para "http" quando uma API real for configurada.
CPF_PROVIDER=mock
CPF_PROVIDER_BASE_URL=
CPF_PROVIDER_API_KEY=
CPF_CACHE_TTL_DIAS=30

# Woovi / OpenPix - pagamentos Pix
WOOVI_APP_ID=
WOOVI_BASE_URL=https://api.woovi.com
WOOVI_WEBHOOK_SECRET=

# App
SECRET_KEY=troque-esta-chave-em-producao
SITE_NAME=ConsultaCPF
SITE_URL=http://localhost:8000
REPORT_PRICE_CENTS=2990
ENVIRONMENT=development

# E-mail promovido automaticamente a role=admin ao logar/cadastrar
ADMIN_EMAIL=
